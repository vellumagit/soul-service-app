# Neon Postgres connection string.
# Get this from https://console.neon.tech → your project → Connection Details → "Pooled connection"
# It looks like: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional: when you migrate to Supabase later, change this to your Supabase pooler URL
# (Project Settings → Database → Connection Pooling → URI)
# and swap the driver in src/db/index.ts (see comment there).

# ─────────────────────────────────────────────────────────────────────────────
# Auth (magic-link sign-in)
# ─────────────────────────────────────────────────────────────────────────────

# Random secret used to sign session JWTs. Must be ≥32 characters.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Comma-separated allowlist of emails permitted to sign in.
# Anyone not on this list is silently rejected (their request still LOOKS
# successful so we don't leak who has access). Lower-cased on compare.
# Example: ALLOWED_EMAILS=svitlana@example.com,musilek.brian@gmail.com
ALLOWED_EMAILS=

# ─────────────────────────────────────────────────────────────────────────────
# Resend — used for magic-link sign-in emails AND for sending client emails
# from the EmailComposer. Get a key at https://resend.com → API Keys.
# ─────────────────────────────────────────────────────────────────────────────

RESEND_API_KEY=

# The "From" address used on all outgoing emails. Must be a verified
# Resend sender (a verified domain you own, or resend's onboarding sender).
# Example: AUTH_EMAIL_FROM="Soul Service <hello@soulservice.app>"
AUTH_EMAIL_FROM=

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic API key — used by the AI session-notes feature.
# Get one at https://console.anthropic.com → Settings → API Keys.
# Cost is a few cents per session for transcript→notes structuring.
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar / Meet OAuth (for auto-Meet-link generation + auto-invites)
# One-time Google Cloud Console setup — see README → Google Calendar setup.
# After you've created the OAuth client, paste the values here.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: explicit base URL for OAuth redirects + magic-link emails.
# Auto-detected on Vercel from VERCEL_URL; defaults to http://localhost:3000
# in dev. Set this if you use a custom domain (e.g. https://app.soulservice.com).
APP_URL=
