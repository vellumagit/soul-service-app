# Neon Postgres connection string.
# Get this from https://console.neon.tech → your project → Connection Details → "Pooled connection"
# It looks like: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional: when you migrate to Supabase later, change this to your Supabase pooler URL
# (Project Settings → Database → Connection Pooling → URI)
# and swap the driver in src/db/index.ts (see comment there).

# Anthropic API key — used by the AI session-notes feature.
# Get one at https://console.anthropic.com → Settings → API Keys.
# Cost is a few cents per session for transcript→notes structuring.
ANTHROPIC_API_KEY=

# Google Calendar / Meet OAuth (for auto-Meet-link generation + auto-invites)
# One-time Google Cloud Console setup — see README → Google Calendar setup.
# After you've created the OAuth client, paste the values here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: explicit base URL for the OAuth redirect. Auto-detected on Vercel
# from VERCEL_URL; defaults to http://localhost:3000 in dev. Set this if you
# use a custom domain (e.g. https://app.soulservice.com).
APP_URL=
