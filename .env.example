# Neon Postgres connection string.
# Get this from https://console.neon.tech → your project → Connection Details → "Pooled connection"
# It looks like: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Auth — type-your-email sign-in, multi-account
#
# Each allowlisted email gets its own isolated account (its own clients,
# sessions, templates, settings). On first sign-in the account is created
# automatically and seeded with starter templates.
# ─────────────────────────────────────────────────────────────────────────────

# Random secret used to sign session JWTs. Must be ≥32 characters.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Comma-separated allowlist of emails permitted to sign in. Anyone whose
# email isn't on this list is rejected. Lower-cased on compare.
# Example: ALLOWED_EMAILS=svitlana@example.com,musilek.brian@gmail.com
ALLOWED_EMAILS=

# ─────────────────────────────────────────────────────────────────────────────
# Resend — used for sending client emails from the EmailComposer.
# Get a key at https://resend.com → API Keys.
# ─────────────────────────────────────────────────────────────────────────────

RESEND_API_KEY=

# The "From" address used on all outgoing emails. Must be a verified
# Resend sender (a verified domain you own, or resend's onboarding sender).
# Example: AUTH_EMAIL_FROM="Soul Service <hello@soulservice.app>"
AUTH_EMAIL_FROM=

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic API key — used by the AI session-notes feature (incl. the Recall
# notetaker's transcript → notes structuring). Get one at
# https://console.anthropic.com → Settings → API Keys.
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Recall.ai — the AI meeting notetaker. A bot joins the session's Meet call,
# records + transcribes, then webhooks the transcript back to
# /api/webhooks/recall, where Claude structures it into the session notes.
#
# Setup:
#  1. Create an account at https://recall.ai and grab an API key.
#  2. Note your workspace REGION (shown in the dashboard), e.g. us-east-1.
#  3. Add a webhook endpoint pointing at  <your-domain>/api/webhooks/recall
#     subscribed to the  bot.status_change  and  transcript.done  events.
#     Copy its signing secret (starts with `whsec_`) into RECALL_WEBHOOK_SECRET.
#  4. Turn it on in the app: Settings → Auto-notes (enable + auto-add).
# ─────────────────────────────────────────────────────────────────────────────
RECALL_API_KEY=
# One of: us-west-2 | us-east-1 | eu-central-1 | ap-northeast-1
RECALL_REGION=
# The webhook signing secret from Recall's dashboard — includes the whsec_ prefix.
RECALL_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Vercel Blob — for file uploads + avatars + invoice PDFs.
# Auto-injected if you connect Blob storage to the Vercel project.
# ─────────────────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar / Meet OAuth — COMING SOON. UI is hidden for now but the
# code is wired up. Set these if you want to flip it on.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: explicit base URL.
# Auto-detected on Vercel from VERCEL_URL; defaults to http://localhost:3000.
APP_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Vercel Cron — session reminders run hourly via /api/cron/reminders.
# Vercel sends `Authorization: Bearer <CRON_SECRET>` on cron requests.
# Generate any random string (32+ chars) and paste it here AND on Vercel.
# Generate one with: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────
CRON_SECRET=

